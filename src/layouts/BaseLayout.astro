---
import '../styles/global.css';
import {
  type Lang,
  htmlLang,
  useTranslations,
  localizePath,
  unlocalizePath,
  alternatePath,
} from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  /** which language this page is rendered in (default English) */
  lang?: Lang;
  /** override the wrap width (e.g. "wide") */
  wrapClass?: string;
  /** optional JSON-LD object injected into <head> (dogfooding Lesson 0003) */
  jsonld?: Record<string, unknown>;
  /** override the derived canonical (lessons emit their .html URL) */
  canonical?: string;
}

const {
  title,
  description,
  lang = 'en',
  jsonld,
  canonical: canonicalProp,
} = Astro.props;
const t = useTranslations(lang);

const here = Astro.url.pathname;
const canonical = canonicalProp ?? new URL(here, Astro.site).href;

// hreflang: this page in every language + x-default (the English form). The
// counterpart URLs are this path with the locale prefix swapped — when canonical
// is overridden (lessons emit `.html`), derive the alternates from it so they
// agree byte-for-byte with the canonical the page already claims.
const canonicalPath = canonicalProp ? new URL(canonicalProp).pathname : here;
const enPath = unlocalizePath(canonicalPath);
const alternates: { hreflang: string; href: string }[] = [
  { hreflang: htmlLang.en, href: new URL(enPath, Astro.site).href },
  { hreflang: htmlLang.zh, href: new URL(localizePath(enPath, 'zh'), Astro.site).href },
  { hreflang: 'x-default', href: new URL(enPath, Astro.site).href },
];

// Nav targets are authored as canonical (English-form) paths and localized per
// page, so the Chinese nav links stay inside /zh/.
const nav = [
  { href: '/', label: t('nav.home') },
  { href: '/lessons/', label: t('nav.lessons') },
  { href: '/reference/glossary.html', label: t('nav.glossary') },
  { href: '/resources/', label: t('nav.resources') },
  { href: '/tools/', label: t('nav.tools') },
];
const isCurrent = (href: string) =>
  href === '/' ? canonicalPath === '/' : canonicalPath.startsWith(href);
const toggleHref = alternatePath(here, lang === 'en' ? 'zh' : 'en');
---
<!doctype html>
<html lang={htmlLang[lang]}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {alternates.map((a) => (
    <link rel="alternate" hreflang={a.hreflang} href={a.href} />
  ))}
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content={htmlLang[lang].replace('-', '_')} />
  <meta name="twitter:card" content="summary" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'><text y='14' font-size='14'>🔎</text></svg>" />
  {jsonld && <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />}
</head>
<body>
  <header class="site-head">
    <div class="bar">
      <a class="brand" href={localizePath('/', lang)}>SEO<span class="dot">·</span>AEO <span style="color:var(--muted);font-weight:400">{t('brand.tag')}</span></a>
      <nav>
        {nav.map((n) => (
          <a href={localizePath(n.href, lang)} aria-current={isCurrent(n.href) ? 'page' : undefined}>{n.label}</a>
        ))}
        <a class="lang-toggle" href={toggleHref} rel="alternate" hreflang={lang === 'en' ? htmlLang.zh : htmlLang.en}>{t('lang.switch')}</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-foot" set:html={t('footer.html')} />
</body>
</html>
