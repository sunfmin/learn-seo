---
import BaseLayout from './BaseLayout.astro';
import Quiz from '../components/lesson/Quiz.astro';

// Renders a lesson: the site shell (via BaseLayout) + a narrow reading column,
// with the structured tail — quiz, primary source, ask box, pager, footnotes —
// rendered once from frontmatter (ADR 0002), not authored per lesson.
interface Props {
  data: {
    num: string;
    title: string;
    kicker: string;
    sub: string;
    blurb: string;
    quizHeading?: string;
    quiz: { q: string; options: string[]; correct: number; ok: string; no: string }[];
    primarySource: { url: string; label: string; minutes?: number; note: string };
    footnotes: string[];
  };
  next?: { slug: string; title: string } | null;
  canonical?: string;
}
const { data, next, canonical } = Astro.props;
const ps = data.primarySource;
---
<BaseLayout
  title={`Lesson ${data.num} · ${data.title}`}
  description={data.blurb}
  canonical={canonical}
>
  <article class="wrap lesson">
    <p class="kicker">{data.kicker}</p>
    <h1>{data.title}</h1>
    <p class="sub">{data.sub}</p>

    <slot />

    <Quiz questions={data.quiz} heading={data.quizHeading} />

    <div class="primary">
      <div class="ttl">
        Primary source — read this next{ps.minutes ? ` (≈${ps.minutes} min)` : ''}
      </div>
      <a href={ps.url}>{ps.label}</a>
      <p class="pnote">{ps.note}</p>
    </div>

    <div class="ask">
      <b>Stuck or curious?</b> This agent is your teacher. Ask it anything — “show
      me a real robots.txt”, “do Claude and Perplexity retrieve differently?” —
      followups are the fastest way to learn.
    </div>

    <nav class="lesson-nav">
      <a href="/lessons/">← All lessons</a>
      {next && (
        <span class="next">Next: <a href={`/lessons/${next.slug}`}>{next.title}</a> →</span>
      )}
    </nav>

    {data.footnotes.length > 0 && (
      <footer class="footnotes">
        Lesson {data.num} · SEO/AEO for builders.<br />
        <Fragment set:html={data.footnotes.map((f, i) => `[${i + 1}] ${f}`).join(' &nbsp; ')} />
      </footer>
    )}
  </article>
</BaseLayout>

<style>
  .primary { margin: 2.4rem 0 0; background: #fbf6ea; border: 1px solid var(--rule); border-radius: 0.5rem; padding: 1rem 1.2rem; }
  .primary .ttl { font-size: 0.7rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--seo); font-weight: 600; margin-bottom: 0.3rem; }
  .primary .pnote { margin: 0.4rem 0 0; font-size: 0.9rem; color: #555; }
  .ask { background: #eef4ee; border: 1px solid #cfe0cf; border-radius: 0.5rem; padding: 0.8rem 1rem; margin-top: 1.6rem; font-size: 0.92rem; }
  .ask b { color: var(--good); }
  .lesson-nav { margin-top: 2.4rem; font-size: 0.92rem; display: flex; gap: 1.2rem; flex-wrap: wrap; }
  .footnotes { margin-top: 2.6rem; padding-top: 1rem; border-top: 1px solid var(--rule); font-size: 0.85rem; color: var(--muted); }
</style>
