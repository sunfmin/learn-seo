---
import BaseLayout from './BaseLayout.astro';
import Quiz from '../components/lesson/Quiz.astro';
import { type Lang, htmlLang, useTranslations, localizePath } from '../i18n/ui';

// Renders a lesson: the site shell (via BaseLayout) + a narrow reading column,
// with the structured tail — quiz, primary source, ask box, pager, footnotes —
// rendered once from frontmatter (ADR 0002), localized per locale (ADR 0003).
interface Props {
  data: {
    num: string;
    title: string;
    kicker: string;
    sub: string;
    blurb: string;
    quizHeading?: string;
    quiz: { q: string; options: string[]; correct: number; ok: string; no: string }[];
    primarySource: { url: string; label: string; minutes?: number; note: string };
    footnotes: string[];
  };
  next?: { slug: string; title: string } | null;
  lang?: Lang;
  canonical?: string;
}
const { data, next, lang = 'en', canonical } = Astro.props;
const t = useTranslations(lang);
const ps = data.primarySource;
const pageTitle =
  lang === 'zh'
    ? `第 ${data.num} 课 · ${data.title}`
    : `Lesson ${data.num} · ${data.title}`;
const minutes = ps.minutes ? ` (≈${ps.minutes} ${t('lesson.primary.min')})` : '';

// Dogfooding Lesson 0003: every lesson page emits structured data — a
// LearningResource that's part of the Course, with the primary source as a
// citation (the machine-readable E-E-A-T sourcing signal from 0008).
const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'LearningResource',
  '@id': canonical,
  url: canonical,
  name: pageTitle,
  description: data.blurb,
  inLanguage: htmlLang[lang],
  learningResourceType: 'lesson',
  educationalLevel: 'beginner',
  position: Number(data.num),
  isPartOf: { '@type': 'Course', name: 'SEO & AEO for builders' },
  publisher: { '@type': 'Organization', name: 'learn-seo' },
  citation: ps.url,
};
---
<BaseLayout
  title={pageTitle}
  description={data.blurb}
  lang={lang}
  canonical={canonical}
  jsonld={jsonld}
>
  <article class="wrap lesson">
    <p class="kicker">{data.kicker}</p>
    <h1>{data.title}</h1>
    <p class="sub">{data.sub}</p>

    <slot />

    <Quiz questions={data.quiz} heading={data.quizHeading} lang={lang} />

    <div class="primary">
      <div class="ttl">{t('lesson.primary.title')}{minutes}</div>
      <a href={ps.url}>{ps.label}</a>
      <p class="pnote">{ps.note}</p>
    </div>

    <div class="ask" set:html={t('lesson.ask.html')} />

    <nav class="lesson-nav">
      <a href={localizePath('/lessons/', lang)}>{t('lesson.nav.all')}</a>
      {next && (
        <span class="next">{t('lesson.nav.next')} <a href={localizePath(`/lessons/${next.slug}`, lang)}>{next.title}</a> →</span>
      )}
    </nav>

    {data.footnotes.length > 0 && (
      <footer class="footnotes">
        {lang === 'zh' ? `第 ${data.num} 课 · ` : `Lesson ${data.num} · `}{t('lesson.footer.tail')}<br />
        <Fragment set:html={data.footnotes.map((f, i) => `[${i + 1}] ${f}`).join(' &nbsp; ')} />
      </footer>
    )}
  </article>
</BaseLayout>

<style>
  .primary { margin: 2.4rem 0 0; background: #fbf6ea; border: 1px solid var(--rule); border-radius: 0.5rem; padding: 1rem 1.2rem; }
  .primary .ttl { font-size: 0.7rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--seo); font-weight: 600; margin-bottom: 0.3rem; }
  .primary .pnote { margin: 0.4rem 0 0; font-size: 0.9rem; color: #555; }
  .ask { background: #eef4ee; border: 1px solid #cfe0cf; border-radius: 0.5rem; padding: 0.8rem 1rem; margin-top: 1.6rem; font-size: 0.92rem; }
  .ask :global(b) { color: var(--good); }
  .lesson-nav { margin-top: 2.4rem; font-size: 0.92rem; display: flex; gap: 1.2rem; flex-wrap: wrap; }
  .footnotes { margin-top: 2.6rem; padding-top: 1rem; border-top: 1px solid var(--rule); font-size: 0.85rem; color: var(--muted); }
</style>
