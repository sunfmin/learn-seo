---
// The horizontal stage-flow diagram (Lesson 0001's two pipelines). Named
// .pipe-flow to avoid colliding with global.css's .pipe (the hub-page column).
interface Stage { name: string; do: string; }
interface Props {
  variant: 'seo' | 'aeo';
  label: string;
  stages: Stage[];
  /** optional italic note under the flow (raw HTML allowed) */
  feeds?: string;
}
const { variant, label, stages, feeds } = Astro.props;
---
<div class:list={['pipe-flow', variant]}>
  <div class="label">{label}</div>
  <div class="flow">
    {stages.map((s, i) => (
      <>
        <div class="stage">
          <span class="s-name">{s.name}</span>
          <span class="s-do">{s.do}</span>
        </div>
        {i < stages.length - 1 && <span class="arrow">→</span>}
      </>
    ))}
  </div>
  {feeds && <p class="feeds" set:html={feeds} />}
</div>
<style>
  .pipe-flow { margin: 1.8rem 0 1rem; }
  .label { font-size: 0.7rem; letter-spacing: 0.16em; text-transform: uppercase; font-weight: 600; margin-bottom: 0.5rem; }
  .pipe-flow.seo .label { color: var(--seo); }
  .pipe-flow.aeo .label { color: var(--aeo); }
  .flow { display: flex; flex-wrap: wrap; align-items: stretch; gap: 0.35rem; }
  .stage { flex: 1 1 0; min-width: 6.6rem; border-radius: 0.45rem; padding: 0.6rem 0.55rem; text-align: center; border: 1px solid var(--rule); }
  .pipe-flow.seo .stage { background: var(--seobg); }
  .pipe-flow.aeo .stage { background: var(--aeobg); }
  .s-name { font-weight: 600; font-size: 0.95rem; display: block; }
  .s-do { font-size: 0.74rem; color: #555; display: block; margin-top: 0.15rem; line-height: 1.3; }
  .arrow { align-self: center; color: var(--muted); font-size: 1.1rem; flex: 0 0 auto; }
  .feeds { text-align: center; color: var(--muted); font-size: 0.82rem; font-style: italic; margin: 0.6rem 0 0; }
  .feeds :global(b) { font-style: normal; color: var(--aeo); }
</style>
