---
import BaseLayout from '../../layouts/BaseLayout.astro';

// The shared glossary. Was a self-contained file synced into public/ (ADR 0002);
// now a real page on BaseLayout + global.css, so the sync path could be retired.
// `glossary.html.astro` keeps the existing /reference/glossary.html URL.
const canonical = new URL('/reference/glossary.html', Astro.site).href;

type Term = { t: string; tag: 'seo' | 'aeo' | 'both'; d: string };
const groups: { h: string; terms: Term[] }[] = [
  {
    h: 'The fields',
    terms: [
      { t: 'SEO — Search Engine Optimization', tag: 'seo', d: 'Making a site rank higher in classic search results pages (the "ten blue links"). Optimizes for the <em>crawl → index → rank → serve</em> pipeline.' },
      { t: 'AEO — Answer Engine Optimization', tag: 'aeo', d: 'Making your content the source an AI answer engine <em>cites</em> when it generates a reply (ChatGPT, Claude, Perplexity, Google AI Overviews). Sometimes called GEO.' },
      { t: 'GEO — Generative Engine Optimization', tag: 'aeo', d: 'Academic name for AEO, from the GEO research paper. Same goal: visibility inside generated answers, not just ranked links.' },
    ],
  },
  {
    h: 'The classic pipeline',
    terms: [
      { t: 'Crawling', tag: 'seo', d: 'A bot (e.g. Googlebot) fetches your pages by following links and reading your <code>sitemap.xml</code>. Gated by <code>robots.txt</code>.' },
      { t: 'Indexing', tag: 'seo', d: "The engine parses a crawled page, renders it, and stores it in a giant searchable database. A page that isn't indexed can never rank." },
      { t: 'Rendering (two-wave / deferred)', tag: 'both', d: 'Google processes JS pages in phases: it crawls the <em>raw HTML</em> first, then — in a <em>separate, deferred queue</em>, once resources allow — a headless Chrome runs the JavaScript and re-indexes what it produced. Content that only exists after JS is indexed late, or never by bots that don\'t render.' },
      { t: 'CSR vs SSR / SSG', tag: 'both', d: '<b>Client-side rendering (CSR):</b> the server sends an empty shell (<code>&lt;div id="root"&gt;</code>) and JS builds the page in the browser — invisible to no-JS bots. <b>Server-side rendering (SSR)</b> / <b>static site generation (SSG):</b> the content is in the first HTML response, seen by every bot immediately. For SEO/AEO, get facts into the server\'s HTML.' },
      { t: 'Ranking', tag: 'seo', d: 'For a given query, the engine orders indexed pages by hundreds of signals (relevance, links, quality, freshness). Decides position.' },
      { t: 'Serving / SERP', tag: 'seo', d: 'The Search Engine Results Page actually shown to the user — links, plus features like snippets, knowledge panels, and AI Overviews.' },
    ],
  },
  {
    h: 'The answer-engine pipeline',
    terms: [
      { t: 'Retrieval', tag: 'aeo', d: 'The answer engine pulls candidate passages — usually from the <em>same crawled/indexed web</em> (often via a live search) — to ground its answer. This is why indexing still matters for AEO.' },
      { t: 'Synthesis / Generation', tag: 'aeo', d: 'The LLM writes a single composed answer from the retrieved passages plus its training knowledge.' },
      { t: 'Citation', tag: 'aeo', d: 'The link/attribution the engine shows next to (or behind) its answer. Being the cited source is the AEO win — the equivalent of a #1 rank.' },
      { t: 'Passage / chunk', tag: 'aeo', d: 'The retrieval unit. Engines split pages into smaller passages, embed them, and pull the few most relevant — so the thing that gets cited is a <em>self-contained chunk</em>, not the whole page. Write each section to stand alone.' },
      { t: 'Answer-first (inverted pyramid)', tag: 'aeo', d: "Lead with the direct answer in 1–2 sentences, then expand with detail. Makes the opening a quotable, self-contained chunk an engine can lift verbatim. Borrowed from journalism's inverted pyramid." },
    ],
  },
  {
    h: 'Quality & trust',
    terms: [
      { t: 'E-E-A-T', tag: 'both', d: '<b>Experience, Expertise, Authoritativeness, Trust</b> — Google\'s framework for "is this content trustworthy?", used by quality raters. <em>Trust is the centre</em>; the others feed it. <b>Not a direct ranking factor and not a score</b> — Google approximates it with "a mix of factors." For builders: audit the machine-detectable proxies (author + <code>sameAs</code>, dates, publisher, outbound sourcing, about/contact).' },
      { t: 'YMYL — Your Money or Your Life', tag: 'seo', d: 'Topics that could significantly affect health, financial stability, safety, or societal well-being. Held to a far higher E-E-A-T bar — trust signals matter most here, and faking them is risky.' },
      { t: 'sameAs', tag: 'both', d: 'A schema.org property linking an entity (a <code>Person</code> author, an <code>Organization</code>) to its authoritative profiles elsewhere (LinkedIn, Wikipedia, ORCID). The machine-readable way to assert <em>who</em> an author is — an Authoritativeness signal.' },
    ],
  },
  {
    h: 'Builder-facing artifacts',
    terms: [
      { t: 'Structured data', tag: 'both', d: 'Machine-readable markup (usually <code>schema.org</code> JSON-LD) embedded in a page that tells engines exactly what an entity is. Powers rich results and helps machines extract facts.' },
      { t: 'JSON-LD', tag: 'both', d: 'Google\'s recommended structured-data format: a <code>&lt;script type="application/ld+json"&gt;</code> block of JSON, kept separate from visible HTML. Each type has <em>required</em> properties (miss one → no rich result) and <em>recommended</em> ones.' },
      { t: 'Rich result', tag: 'seo', d: 'An enhanced SERP listing — star ratings, prices, FAQ accordions — earned by valid structured data. Takes more space, draws more clicks than a plain blue link.' },
      { t: 'robots.txt', tag: 'both', d: 'A file at your site root that tells crawlers which paths they may or may not fetch. First thing a crawler reads.' },
      { t: 'sitemap.xml', tag: 'both', d: 'A machine-readable list of your URLs (with metadata) that helps crawlers discover pages efficiently. <em>Passive</em>: engines pull it on their own schedule. Spec limits: ≤50,000 URLs and ≤50 MB per file; <code>&lt;loc&gt;</code> required, <code>&lt;lastmod&gt;</code> optional (W3C date); all URLs on one host. Past 50k URLs, use a <b>sitemap index</b> (a sitemap of sitemaps).' },
      { t: 'IndexNow', tag: 'both', d: 'An open protocol to <em>actively push</em> changed URLs to engines: <code>POST {host, key, keyLocation, urlList}</code> (≤10,000 URLs/post), and the ping is shared across all participants. Supported by Bing, Yandex, Naver, Seznam — <b>not Google</b>, which sticks to sitemaps + its own crawl scheduling. The key (8–128 chars) lives in a file at your root to prove host ownership.' },
      { t: 'noindex', tag: 'seo', d: 'A directive telling the engine to drop a page from the index. Lives in <code>&lt;meta name="robots"&gt;</code> or the <code>X-Robots-Tag</code> header. Only works if the page is <em>crawlable</em> — a blocked page\'s noindex is never read.' },
      { t: 'X-Robots-Tag', tag: 'seo', d: 'An HTTP response header that carries indexing directives (like <code>noindex</code>) — the header-level equivalent of the robots meta tag. Useful for non-HTML files (PDFs, images).' },
      { t: 'Canonical', tag: 'both', d: 'Via <code>&lt;link rel="canonical"&gt;</code>: declares which URL is the "real" one when several show near-identical content, so the engine consolidates signals onto one.' },
      { t: 'Search Console (API)', tag: 'seo', d: "Google's first-party feed for your site: impressions, clicks, average position, and the queries that surfaced you — from Google's own logs. The <code>searchanalytics.query</code> endpoint makes it pollable. The <code>Web</code> search type now includes AI-feature traffic." },
      { t: 'Share of voice', tag: 'aeo', d: "Your slice of all citations across a prompt set: <em>your citations ÷ everyone's citations</em>. The headline AEO metric — but a <em>proxy</em>, since the prompt set is sampled, not the engine's real traffic. Pair with <em>coverage</em> (% of prompts that cite you at all)." },
    ],
  },
];
---
<BaseLayout
  title="Glossary — SEO / AEO for Builders"
  description="Shared vocabulary for SEO, AEO, and the automation built on top — tagged SEO (classic search), AEO (AI answer engines), or BOTH."
  canonical={canonical}
>
  <div class="wrap">
    <p class="kicker">Reference · adhere to these definitions in every lesson</p>
    <h1>Glossary</h1>
    <p class="sub">Shared vocabulary for SEO, AEO, and the automation built on top of them. Tags: <span class="tag seo">SEO</span> classic search · <span class="tag aeo">AEO</span> AI answer engines · <span class="tag both">BOTH</span></p>

    {groups.map((g) => (
      <div class="grp">
        <h2>{g.h}</h2>
        <dl>
          {g.terms.map((term) => (
            <>
              <dt>{term.t} <span class:list={['tag', term.tag]}>{term.tag.toUpperCase()}</span></dt>
              <dd set:html={term.d} />
            </>
          ))}
        </dl>
      </div>
    ))}

    <footer class="gloss-foot">
      Part of the SEO/AEO learning workspace · see <a href="/lessons/0001-the-two-pipelines.html">Lesson 0001</a> · grounded in <a href="/">the mission</a>.<br />
      Ask your teacher (this agent) to clarify or expand any term.
    </footer>
  </div>
</BaseLayout>

<style>
  dl { margin: 0; }
  dt { font-weight: 600; font-size: 1.05rem; margin-top: 1.6rem; color: var(--ink); }
  dt .tag { margin-left: 0.4rem; vertical-align: middle; }
  dd { margin: 0.25rem 0 0; color: #333; }
  .grp { margin-top: 2.6rem; padding-top: 0.4rem; border-top: 2px solid var(--rule); }
  .grp h2 { font-size: 0.8rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); font-weight: 600; }
  .gloss-foot { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--rule); font-size: 0.85rem; color: var(--muted); }
</style>
