---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { tools, slugForLesson } from '../../data/lessons';
---
<BaseLayout
  title="Tools — SEO & AEO for builders"
  description="Eight stdlib-only Python tools, one per lesson: crawl audit, JSON-LD linter, GEO linter, citation tracker, render-gap diff, sitemap/IndexNow, E-E-A-T audit."
>
  <div class="wrap wide">
    <p class="kicker">The toolkit · {tools.length} scripts</p>
    <h1>Tools</h1>
    <p class="sub">Stdlib-only Python, no pip install. Each has an offline <code>--demo</code> self-check and a docstring with usage. The lesson teaches the why; the tool is the how.</p>

    <p style="font-size:.92rem; color:var(--muted)">
      All live in <code>tools/</code> in the repo. Each splits a network/UI edge from
      an offline, testable core — so the logic is verifiable without hitting the wire.
    </p>

    {tools.map((t) => (
      <div style="border:1px solid var(--rule); border-radius:.6rem; background:#fff; padding:1rem 1.1rem; margin:1rem 0">
        <div style="display:flex; align-items:baseline; gap:.6rem; flex-wrap:wrap">
          <code style="font-size:1.02rem; background:var(--seobg); color:var(--seo)">{t.name}</code>
          <a style="font-size:.78rem; color:var(--muted)" href={`/lessons/${slugForLesson(t.lesson)}`}>from Lesson {t.lesson} →</a>
        </div>
        <p style="margin:.5rem 0 .6rem; font-size:.94rem; color:#333">{t.desc}</p>
        <pre><code>$ {t.run}</code></pre>
      </div>
    ))}
  </div>
</BaseLayout>
