---
import { getCollection, render } from 'astro:content';
import LessonLayout from '../../layouts/LessonLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('lessons');
  // slug carries `.html` so the URL stays /lessons/<id>.html (ADR 0002).
  return entries.map((entry) => ({ params: { slug: `${entry.id}.html` }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Next-lesson pager, derived from collection order (the single source of truth).
const ordered = (await getCollection('lessons')).sort((a, b) =>
  a.data.num.localeCompare(b.data.num),
);
const i = ordered.findIndex((e) => e.id === entry.id);
const nextEntry = i >= 0 && i + 1 < ordered.length ? ordered[i + 1] : null;
const next = nextEntry ? { slug: `${nextEntry.id}.html`, title: nextEntry.data.title } : null;
const canonical = new URL(`/lessons/${entry.id}.html`, Astro.site).href;
---
<LessonLayout data={entry.data} next={next} canonical={canonical}>
  <Content />
</LessonLayout>
