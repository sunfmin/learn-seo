---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { toolsForLesson } from '../../data/lessons';

const lessons = (await getCollection('lessons')).sort((a, b) =>
  a.data.num.localeCompare(b.data.num),
);
---
<BaseLayout
  title="Lessons — SEO & AEO for builders"
  description="Eight short, developer-first lessons spanning classic search and AI answer engines, each with a runnable audit/automation tool."
  jsonld={{
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    itemListElement: lessons.map((l, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: `Lesson ${l.data.num}: ${l.data.title}`,
      url: `${Astro.site}lessons/${l.id}.html`,
    })),
  }}
>
  <div class="wrap wide">
    <p class="kicker">The course · {lessons.length} lessons</p>
    <h1>Lessons</h1>
    <p class="sub">Each one ends in a tangible win — a script you run, a page you fix, a number you can track.</p>

    <div class="grid">
      {lessons.map((l) => (
        <a class="card" href={`/lessons/${l.id}.html`}>
          <span class="num">Lesson {l.data.num}</span>
          <span class="ct">{l.data.title}</span>
          <span class="cd">{l.data.blurb}</span>
          {toolsForLesson(l.data.num).length > 0 && (
            <span class="tool">▸ {toolsForLesson(l.data.num).map((t) => t.name).join(' · ')}</span>
          )}
        </a>
      ))}
    </div>

    <p style="margin-top:2rem; font-size:.92rem; color:var(--muted)">
      Also: the <a href="/reference/glossary.html">glossary</a> (shared vocabulary,
      tagged SEO / AEO / BOTH) and the <a href="/resources/">resources</a> (every
      primary source the lessons cite).
    </p>
  </div>
</BaseLayout>
