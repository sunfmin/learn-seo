---
import { render } from 'astro:content';
import LessonLayout from '../../layouts/LessonLayout.astro';
import { lessonPaths } from '../../data/lessonRoute';

export async function getStaticPaths() {
  return lessonPaths('en');
}

const { entry, next } = Astro.props;
const { Content } = await render(entry);
const canonical = new URL(`/lessons/${Astro.params.slug}.html`, Astro.site).href;
---
<LessonLayout data={entry.data} next={next} lang="en" canonical={canonical}>
  <Content />
</LessonLayout>
